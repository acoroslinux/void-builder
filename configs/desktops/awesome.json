{
  "package_sources": {
    "official": [
      "awesome",
      "lightdm",
      "lightdm-gtk-greeter",
      "lightdm-gtk-greeter-settings",
      "network-manager-applet",
      "xterm"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "Awesome Window Manager",
    "description": "Highly configurable, next generation framework window manager for X.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/awesome",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}