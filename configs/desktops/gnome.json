{
  "package_sources": {
    "official": [
      "gnome",
      "gdm"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "gdm"
    ]
  },
  "desktop_environment": {
    "name": "GNOME Desktop",
    "description": "Modern and intuitive desktop environment.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/gnome",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
