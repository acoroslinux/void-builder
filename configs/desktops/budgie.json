{
  "package_sources": {
    "official": [
      "budgie-desktop",
      "lightdm",
      "lightdm-gtk-greeter",
      "network-manager-applet"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "Budgie Desktop",
    "description": "Modern desktop environment designed with simplicity and elegance in mind.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/budgie",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
