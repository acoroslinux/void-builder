{
  "package_sources": {
    "official": [
      "openbox",
      "obconf",
      "tint2",
      "feh",
      "pcmanfm",
      "lightdm",
      "lightdm-gtk-greeter",
      "lightdm-gtk-greeter-settings",
      "network-manager-applet"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "Openbox Window Manager",
    "description": "Highly configurable and lightweight stacking window manager.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/openbox",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}