{
  "package_sources": {
    "official": [
      "herbstluftwm",
      "dmenu",
      "lightdm",
      "lightdm-gtk-greeter",
      "network-manager-applet",
      "xterm"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "Herbstluftwm Window Manager",
    "description": "Manual tiling window manager for X11 using keybindings and scripts.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/herbstluftwm",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
