{
  "package_sources": {
    "official": [
      "enlightenment",
      "terminology",
      "lightdm",
      "lightdm-gtk-greeter",
      "lightdm-gtk-greeter-settings",
      "network-manager-applet"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "Enlightenment Desktop",
    "description": "Stunning, fast, and modular window manager and desktop environment.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/enlightenment",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}