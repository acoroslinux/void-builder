{
  "package_sources": {
    "official": [
      "lxqt",
      "sddm",
      "network-manager-applet",
      "pcmanfm-qt"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "sddm"
    ]
  },
  "desktop_environment": {
    "name": "LXQt Desktop",
    "description": "Lightweight and modular Qt desktop environment.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/lxqt",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
