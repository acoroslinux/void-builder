{
  "package_sources": {
    "official": [
      "qtile",
      "lightdm",
      "lightdm-gtk-greeter",
      "lightdm-gtk-greeter-settings",
      "network-manager-applet",
      "xterm"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "Qtile Window Manager",
    "description": "Full-featured, hackable tiling window manager written and configured in Python.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/qtile",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}