{
  "package_sources": {
    "official": [
      "cinnamon",
      "lightdm",
      "lightdm-gtk-greeter",
      "lightdm-gtk-greeter-settings",
      "network-manager-applet"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "Cinnamon Desktop",
    "description": "Modern, clean, and comfortable desktop environment.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/cinnamon",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}