{
  "package_sources": {
    "official": [
      "icewm",
      "lightdm",
      "lightdm-gtk-greeter",
      "lightdm-gtk-greeter-settings",
      "network-manager-applet",
      "xterm"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "IceWM Window Manager",
    "description": "Very fast, lightweight, and retro stacking window manager.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/icewm",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}