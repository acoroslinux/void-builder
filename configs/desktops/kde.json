{
  "package_sources": {
    "official": [
      "kde-plasma",
      "kde-apps",
      "sddm",
      "plasma-nm"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "sddm"
    ]
  },
  "desktop_environment": {
    "name": "KDE Plasma Desktop",
    "description": "Modern, beautiful, and highly customizable desktop environment.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/kde",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
