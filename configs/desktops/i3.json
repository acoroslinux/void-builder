{
  "package_sources": {
    "official": [
      "i3-gaps",
      "i3status",
      "dmenu",
      "i3lock",
      "xterm",
      "lightdm",
      "lightdm-gtk-greeter",
      "lightdm-gtk-greeter-settings",
      "network-manager-applet",
      "feh",
      "dunst"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "i3 Tiling Window Manager",
    "description": "Lightweight and efficient tiling window manager.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/i3",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}