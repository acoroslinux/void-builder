{
  "package_sources": {
    "official": [
      "bspwm",
      "sxhkd",
      "feh",
      "dmenu",
      "lightdm",
      "lightdm-gtk-greeter",
      "network-manager-applet",
      "xterm"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "bspwm Window Manager",
    "description": "Tiling window manager that represents windows as the leaves of a full binary tree.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/bspwm",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
