{
  "package_sources": {
    "official": [
      "fluxbox",
      "feh",
      "lightdm",
      "lightdm-gtk-greeter",
      "network-manager-applet",
      "xterm"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "Fluxbox Window Manager",
    "description": "Lightweight stacking window manager for X, based on Blackbox.",
    "customizations_path": "custom_files/",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/fluxbox",
        "destination": "/etc/skel/.config"
      }
    ]
  }
}
