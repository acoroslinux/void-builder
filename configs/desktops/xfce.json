{
  "package_sources": {
    "official": [
      "xfce4",
      "xfce4-power-manager",
      "lightdm",
      "lightdm-gtk-greeter",
      "network-manager-applet",
      "file-roller",
      "mousepad",
      "galculator",
      "ristretto",
      "xfce4-plugins"
    ]
  },
  "customizations": {
    "services": [
      "dbus",
      "lightdm"
    ]
  },
  "desktop_environment": {
    "name": "XFCE Desktop",
    "description": "Lightweight, fast, and user-friendly desktop environment.",
    "customizations_path": "configs/custom_files",
    "use_common_config": true,
    "copy_files": [
      {
        "source": "desktop-config/xfce",
        "destination": "/etc/skel/.config"
      },
      {
        "source": "etc/lightdm/lightdm.conf.d/10-autologin.conf",
        "destination": "/etc/lightdm/lightdm.conf.d/10-autologin.conf"
      }
    ]
  }
}
