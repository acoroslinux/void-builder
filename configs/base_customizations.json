{
  "base_copy_files": [
    {
      "source": "os-release",
      "destination": "/usr/lib"
    },
    {
      "source": "calamares",
      "destination": "/etc/calamares"
    },
    {
      "source": "calamares/branding",
      "destination": "/usr/share/calamares/branding"
    },
    {
      "source": "skel",
      "destination": "/etc/skel"
    },
    {
      "source": "autostart",
      "destination": "/etc/xdg/autostart"
    },
    {
      "source": "applications",
      "destination": "/usr/share/applications"
    },
    {
      "source": "plymouth",
      "destination": "/usr/share/plymouth/themes"
    },
    {
      "source": "lightdm",
      "destination": "/etc/lightdm"
    },
    {
      "source": "samba",
      "destination": "/etc/samba"
    },
    {
      "source": "sudoers.d",
      "destination": "/etc/sudoers.d"
    },
    {
      "source": "default",
      "destination": "/etc/default"
    },
    {
      "source": "scripts",
      "destination": "/usr/local/bin"
    }
  ]
}
