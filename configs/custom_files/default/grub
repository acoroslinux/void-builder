# GRUB boot loader configuration
# Generated by Arch Modern build system
# This file is used by grub-mkconfig to generate /boot/grub/grub.cfg

# Distributor name shown in the GRUB menu
GRUB_DISTRIBUTOR="Arch Modern"

# Default boot entry (0 = first entry)
GRUB_DEFAULT=0

# How many seconds to wait at the boot menu before booting the default entry
GRUB_TIMEOUT=5
GRUB_TIMEOUT_STYLE=menu

# Display the boot menu even if only one OS is detected
GRUB_DISABLE_SUBMENU=true

# Graphical output settings
GRUB_GFXMODE=auto
GRUB_GFXPAYLOAD_LINUX=keep

# Kernel parameters appended to all boot entries
# - quiet:       suppress verbose kernel output
# - splash:      enable Plymouth boot splash
# - loglevel=3:  only show kernel errors and above
GRUB_CMDLINE_LINUX_DEFAULT="quiet splash loglevel=3"

# Extra kernel parameters (for all menu entries, including recovery)
GRUB_CMDLINE_LINUX=""

# Uncomment to disable generation of recovery mode menu entries
# GRUB_DISABLE_RECOVERY=true

# Uncomment to detect other operating systems on the disk
GRUB_DISABLE_OS_PROBER=false

# Preload additional GRUB modules
GRUB_PRELOAD_MODULES="part_gpt part_msdos"

# GRUB BIOS installation target partition offset
GRUB_FORCE_PARTUUID=""
